# Maintainer: Daniel Bermond <dbermond@archlinux.org>

pkgname=rockchip-mpp
pkgver=1.0.11
pkgrel=6
pkgdesc='Rockchip Media Process Platform (MPP)'
arch=('aarch64')
url='https://github.com/sykum/mpp/'
license=('Apache-2.0' 'MIT')
_srcname=${pkgver}-ml
depends=(
    'gcc-libs'
    'glibc')
makedepends=(
    'cmake')
source=("https://github.com/sykum/mpp/archive/refs/heads/${_srcname}.zip")

build() {
    # fix build with gcc 15
    export CFLAGS+=' -Wno-error=incompatible-pointer-types'
    
    cmake -B build -S "mpp-${_srcname}" \
        -G 'Unix Makefiles' \
        -DCMAKE_BUILD_TYPE:STRING='None' \
        -DCMAKE_INSTALL_PREFIX:PATH='/usr' \
        -DENABLE_VPROC_VDPP:BOOL='ON' \
        -Wno-dev
    cmake --build build
}

check() {
    ctest --test-dir build --output-on-failure
}

package() {
    DESTDIR="$pkgdir" cmake --install build
    install -D -m644 "mpp-${_srcname}/LICENSES/MIT" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-MIT"
}
sha256sums=('d1810574dfff9ec8328ded97f65b8fb93401279088d7e7c60960ecf3388e4b51')
